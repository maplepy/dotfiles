# Application settings that change frequently
settings.json
*.db
*.sqlite
*.sqlite3
cache/
Cache/
CachedData/
logs/
Logs/
*.log

# FreeTube settings (changes frequently)
.config/FreeTube/

# Temporary files
*.tmp
*.temp
*~
.#*

# OS specific
.DS_Store
Thumbs.db

{{- if eq .machine_type "server" }}
# For servers, only allow essential configs
*
!.config/
!.config/fish/
!.config/git/
!.config/helix/
!.chezmoiscripts/
{{- end }}

{{- if not .gaming }}
# Gaming-specific configurations
.config/steamtinkerlaunch
.config/gamemode.ini
.config/MangoHud
{{- end }}

{{- if ne .wm "hyprland" }}
# Ignore Hyprland-specific files if not using Hyprland
run_once_install-hyprland-packages.sh.tmpl
.config/hypr
.config/matugen
{{- end }}

{{- if ne .suite "standard" }}
# Standard suite: waybar, swaync, wlogout, dunst, rofi
.config/waybar
.config/swaync
.config/wlogout
.config/dunst
.config/rofi
{{- end }}

{{- if ne .suite "quickshell" }}
# Quickshell suite configs
.config/quickshell
{{- end }}

{{- if eq .environment "work" }}
# Personal files for work setups
{{- end }}

{{- if eq .environment "school" }}
# Ignore everything except fish, git, and nvim configs for school setups
**

!.config
!.config/git/**
!.config/fish/**
!.config/nvim/**
!.config/opencode/**
{{- end }}

{{- if not .package_management }}
# Package installation scripts when packages can't be installed
.chezmoiscripts/*install*
run_once_*install*
{{- end }}

{{- if ne .chezmoi.os "linux" }}
# Linux-specific files
.chezmoiscripts/linux/**
.local/share/fonts
{{- end }}
