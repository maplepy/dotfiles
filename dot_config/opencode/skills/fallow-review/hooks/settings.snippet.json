{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/fallow-review-session-init.sh"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "feed.jsonl",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/fallow-review-on-feedback.sh"
          }
        ]
      }
    ]
  }
}
