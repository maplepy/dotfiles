{
  "enabled": true,
  "debug": false,
  "patterns": {
    "keywords": [],
    "regex": [
      { "pattern": "sk-[A-Za-z0-9]{48}", "category": "OPENAI_KEY" },
      { "pattern": "(ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9]+", "category": "GITHUB_TOKEN" },
      { "pattern": "AKIA[0-9A-Z]{16}", "category": "AWS_ACCESS_KEY" },
      { "pattern": "[us]-s4t2ud-[a-f0-9]{64}", "category": "FORTY_TWO_KEY" },
      { "pattern": "(?<!\\d)(?:\\+33|0)\\d{9}(?!\\d)", "category": "FR_PHONE" }
    ],
    "builtin": ["ipv4", "mac"],
    "exclude": ["example.com", "localhost", "127.0.0.1"]
  }
}
