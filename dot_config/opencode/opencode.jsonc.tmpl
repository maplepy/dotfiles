{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "formatter": true,
  "agent": {
    "plan": {
      "permission": {
        "edit": {
          "CONTEXT.md": "allow",
          "CONTEXT-MAP.md": "allow",
          "docs/adr/**": "allow",
          "*": "deny"
        },
        "bash": {
          "dex *": "allow",
          "*": "ask"
        }
      }
    }
  },
  "permission": {
    "bash": {
      "rm *": "ask",
      "ls": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "environment": {
        "CONTEXT7_API_KEY": {{ .context7_api_key | default "" | quote }}
      }
    }
  }
}
