#!/bin/bash
# by maplepy
# Git commit message hook to automatically add semantic emojis.
# Combines conventional commits with gitmoji-like prefixes.
#
# How this hook works:
# 1) Parse the first commit-message line as Conventional Commits when possible.
# 2) Map commit type -> emoji.
# 3) Preserve scope and breaking-change marker (!).
# 4) Skip generated commit sources (merge/squash/rebase contexts).
# 5) Fall back to a sensible default prefix when type is unknown.

# Map supported prefixes to emojis.
# Keep this list aligned with team commit conventions.
declare -A prefix_emoji=(
	["init"]="🎉"
	["feat"]="✨"
	["fix"]="🐛"
	["docs"]="📝"
	["style"]="🎨"
	["refactor"]="♻️"
	["perf"]="⚡️"
	["test"]="✅"
	["build"]="🏗️"
	["ci"]="💚"
	["deps"]="📦"
	["revert"]="⏪"
	["wip"]="🚧"
	["config"]="⚙️"
)

# Git passes:
# $1 = path to temporary commit message file
# $2 = commit source (message/template/merge/squash/commit/...)
commit_msg_file="$1"
commit_source="$2"

# Guard against unexpected invocation states.
if [[ ! -f "$commit_msg_file" ]]; then
	echo "Error: Commit message file not found." >&2
	exit 1
fi

# Read the full file. We only rewrite the first-line style, but keep behaviour simple.
commit_msg_content=$(cat "$commit_msg_file")

# Skip auto-generated commit contexts where rewriting is usually undesired.
# Why: merge/squash/amend-generated messages often carry metadata that should stay intact.
case "$commit_source" in
	merge|squash|commit)
		exit 0
		;;
esac

# Rebase flows also generate commit contexts where normalisation is risky.
if [[ "${GIT_REFLOG_ACTION:-}" == rebase* ]]; then
	exit 0
fi

# Fallback type when no valid/known prefix can be extracted.
default_prefix="refactor"

# Debug logging is opt-in to avoid leaking commit text by default.
# Enable with: GIT_HOOK_DEBUG=1 git commit ...
debug_enabled="${GIT_HOOK_DEBUG:-0}"
debug_log="/tmp/git_hook_debug.log"

# Write a debug line only when debug mode is enabled.
debug() {
	[[ "$debug_enabled" == "1" ]] || return 0
	printf '%s\n' "$1" >> "$debug_log"
}

# Trim leading/trailing whitespace from a string.
trim() {
	local var="$*"
	var="${var#"${var%%[![:space:]]*}"}"
	var="${var%"${var##*[![:space:]]}"}"
	printf '%s' "$var"
}

# Lowercase only first character. Used to gently normalise fallback messages.
to_lowercase_first() {
	local str="$1"
	if [[ -n "$str" ]]; then
		local first_char="${str:0:1}"
		local rest="${str:1}"
		printf '%s%s' "${first_char,,}" "$rest"
	fi
}

# Treat any emoji-prefixed message as already formatted.
# Why: users may type their own gitmoji prefix, and the hook should not double-prefix it.
has_emoji() {
	local msg="$1"
	msg="${msg#"${msg%%[![:space:]]*}"}"

	perl -CSDA -e 'exit((($ARGV[0] // q{}) =~ /^\p{Extended_Pictographic}/u) ? 0 : 1)' "$msg"
}

# Do not rewrite commit messages that are already normalised by this hook.
if has_emoji "$commit_msg_content"; then
	debug "DEBUG: Commit already has emoji prefix, skipping."
	exit 0
fi

# Parsed components from Conventional Commit header.
prefix=""
scope=""
message_body_part=""
is_breaking_change=0

# Matches: type(scope)!: subject
# Groups:
# 1 type
# 2 optional scope in parentheses
# 3 optional ! marker
# 4 subject/body first line content
conventional_commit_pattern='^([a-zA-Z]+)(\([^)]*\))?(!?):[[:space:]]*(.*)'

if [[ "$debug_enabled" == "1" ]]; then
	printf '%s\n' "--- New Commit --- $(date)" > "$debug_log"
fi

debug "DEBUG: Original message: [$commit_msg_content]"

# Parse message as Conventional Commit when possible, otherwise fallback.
if [[ $commit_msg_content =~ $conventional_commit_pattern ]]; then
	if [[ -n "${BASH_REMATCH[1]}" ]]; then
		prefix="${BASH_REMATCH[1],,}"
		scope="${BASH_REMATCH[2]}"
		if [[ -n "${BASH_REMATCH[3]}" ]]; then
			is_breaking_change=1
		fi
		message_body_part="${BASH_REMATCH[4]}"
		debug "DEBUG: Regex matched, prefix=[$prefix], scope=[$scope], breaking=[$is_breaking_change], body=[$message_body_part]"
	else
		debug "DEBUG: Match success but empty capture, using default prefix"
		prefix="$default_prefix"
		message_body_part="$commit_msg_content"
	fi
else
	debug "DEBUG: Regex failed to match, using default prefix"
	prefix="$default_prefix"
	message_body_part="$commit_msg_content"
fi

# final_prefix may differ from parsed prefix when parsed type is unknown.
final_prefix="$prefix"
emoji=""
body_content=""

# Unknown type: fallback to default prefix and treat original message as body.
if [[ -z "${prefix_emoji[$prefix]}" ]]; then
	final_prefix="$default_prefix"
	emoji="${prefix_emoji[$final_prefix]}"
	body_content=$(trim "$commit_msg_content")
	body_content=$(to_lowercase_first "$body_content")
	# Drop scope in fallback mode because it belongs to unknown type semantics.
	scope=""
else
	# Known type: keep extracted body text after the colon.
	emoji="${prefix_emoji[$prefix]}"
	body_content=$(trim "$message_body_part")
fi

# Secondary normalisation when message was non-conventional and defaulted.
if [[ "$final_prefix" == "$default_prefix" && ! $commit_msg_content =~ $conventional_commit_pattern ]]; then
	body_content=$(to_lowercase_first "$body_content")
fi

breaking_indicator=""
breaking_marker=""
if [[ $is_breaking_change -eq 1 ]]; then
	# Keep both human signal (emoji) and machine-readable marker (!).
	breaking_indicator="💥 "
	breaking_marker="!"
fi

# Rebuild canonical header.
# If scope exists, remove outer parentheses before re-adding for consistent format.
if [[ -n "$scope" ]]; then
	cleaned_scope="${scope#(}"
	cleaned_scope="${cleaned_scope%)}"
	new_commit_msg="$breaking_indicator$emoji $final_prefix($cleaned_scope)$breaking_marker: $body_content"
else
	new_commit_msg="$breaking_indicator$emoji $final_prefix$breaking_marker: $body_content"
fi

debug "DEBUG: New commit message: [$new_commit_msg]"
# Persist rewritten message back to the file Git will use for the commit.
echo "$new_commit_msg" > "$commit_msg_file"
